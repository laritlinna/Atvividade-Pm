Algoritmo "ex2"


Var
  numero_um:inteiro
  numero_dois:inteiro
  soma:inteiro
Inicio
   escreva("escreva o primeiro numero:" )
   leia(numero_um)
   escreva("escreva o segundo numero:" )
   leia(numero_dois)
   soma <-(numero_um + numero_dois)
   escreva("A soma dos dois valores é: ", soma)
Fimalgoritmo